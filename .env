EARNINGS_CALL_API_KEY=ect_9b5bf121c1a4043d13f27c184a2a7d87169675bbf8bd9c1246c3dea75f72b741

# This machine has 16GB RAM and Ollama has been observed to crash (OOM) when
# panel model calls (qwen2.5:7b + llama3) fire back-to-back, especially under
# concurrent interactive Ollama usage. Space calls out to give the OS/Metal
# time to release memory between calls. See scripts/run_universe.sh for the
# accompanying health-check/retry wrapper used for large batch runs.
OLLAMA_PANEL_SLEEP_SECONDS=10

# 3-judge panel (final, unified -- user wants every ticker scored "apples to
# apples" on the same 3 judges, no mixed panels). Using the exact local tag
# gemma4:e2b-it-qat rather than the "gemma"/"gemma4" shorthand in
# evaluator_config.py -- that alias resolves to "gemma4:26b" (not pulled on
# this machine). e2b-it-qat (4.3GB) was chosen to match llama3/qwen2.5:7b's
# size range (4.7GB each); gemma4:12b (7.6GB) was tried first and replaced
# for being oversized. All 35 analyses completed before this panel was
# finalized were archived to output/_archive_pre_unified_panel/ and are being
# fully rerun -- no ticker in the final output was scored under a different
# panel.
OLLAMA_PANEL_MODELS=qwen2.5:7b,llama3,gemma4:e2b-it-qat
